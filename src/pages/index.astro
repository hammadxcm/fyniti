---
import Layout from '@layouts/Layout.astro';
import Nav from '@components/Nav.astro';
import Hero from '@components/Hero.astro';
import About from '@components/About.astro';
import Services from '@components/Services.astro';
import Process from '@components/Process.astro';
import Technologies from '@components/Technologies.astro';
import Team from '@components/Team.astro';
import Testimonials from '@components/Testimonials.astro';
import Contact from '@components/Contact.astro';
import Footer from '@components/Footer.astro';
---

<Layout>
  <Nav />
  <main style="overflow-x:hidden;">
    <Hero />
    <About />
    <Services />
    <Process />
    <Technologies />
    <Team />
    <Testimonials />
    <Contact />
  </main>
  <Footer />
</Layout>

<script>
  import { initScrollReveal } from '@scripts/observer';
  import { initNav } from '@scripts/nav';
  import { initSmoothScroll } from '@scripts/smooth-scroll';
  import { initThemeSwitcher } from '@scripts/theme-switcher';
  import { initI18n } from '@scripts/i18n';
  import { initCounters } from '@scripts/counter';

  // Critical path — runs immediately
  initNav();
  initSmoothScroll();
  initScrollReveal();
  initThemeSwitcher();
  initCounters();
  initI18n();

  // Helper: lazy-load a module at idle time with error handling
  function lazyLoad(loader: () => Promise<void>, timeout = 2000): void {
    const load = () => loader().catch((e) => console.error('[lazy-load]', e));
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => load(), { timeout });
    } else {
      setTimeout(load, timeout);
    }
  }

  // Defer GSAP (165KB + ScrollTrigger 103KB) — not critical path
  lazyLoad(() => import('@scripts/gsap-init').then((m) => m.initGSAP()));

  // Lazy-load magnetic hover effect
  lazyLoad(() => import('@scripts/magnetic-hover').then((m) => m.initMagneticHover()));

  // Logo morph (FYNITI ↔ infinity) — loads eagerly since first cycle is immediate
  import('@scripts/logo-morph').then((m) => m.initLogoMorph()).catch((e) => console.error('[logo-morph]', e));

  // Logo scramble-reveal on hover
  import('@scripts/logo-scramble').then((m) => m.initLogoScramble()).catch((e) => console.error('[logo-scramble]', e));

  // Lazy-load chatbot at idle time
  lazyLoad(() => import('@scripts/chatbot').then((m) => m.initChatbot()), 3000);
</script>
