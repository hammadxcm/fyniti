---
/**
 * TeamCard — Reusable team member card.
 * Hover sequence: avatar glitch + ring pulse → bio fades → socials appear.
 */
import type { TeamMember } from '@data/site';

interface Props {
  member: TeamMember;
}

const { member } = Astro.props;
---

<div class="tc glass glow-border glass-shimmer rounded-xl">
  <!-- Avatar -->
  <div class="tc-avatar">
    {member.avatar ? (
      <img src={member.avatar} alt={member.name} class="tc-avatar-img" loading="lazy" />
    ) : (
      <span class="tc-initials">{member.initials}</span>
    )}
  </div>

  <h3 class="tc-name">{member.name}</h3>
  <div class="tc-bar" aria-hidden="true"></div>
  <span class="tc-role">{member.role}</span>

  <p class="tc-bio">{member.bio}</p>

  <div class="tc-socials">
    {member.links.map((link) => (
      <a
        href={link.url}
        class="tc-social"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${link.label} - ${member.name}`}
      >
        {link.label === 'Email' && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
        )}
        {link.label === 'LinkedIn' && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        )}
        {link.label === 'GitHub' && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        )}
        {link.label === 'Portfolio' && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><ellipse cx="12" cy="12" rx="5" ry="10"/></svg>
        )}
        {link.label === 'Instagram' && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        )}
      </a>
    ))}
  </div>
</div>

<style>
  /* ── Card ── */
  .tc {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
    max-width: 380px;
    width: 100%;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tc:hover {
    transform: translateY(-4px);
    box-shadow:
      0 0 0 1px var(--color-border-hover),
      0 8px 32px -8px color-mix(in srgb, var(--color-brand) 20%, transparent),
      0 0 48px -12px color-mix(in srgb, var(--color-brand) 10%, transparent);
  }

  /* ── Avatar ── */
  .tc-avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: linear-gradient(135deg, var(--color-brand), var(--color-brand-mint), var(--color-brand-light));
    box-shadow: 0 0 20px color-mix(in srgb, var(--color-brand) 25%, transparent);
    transition: box-shadow 0.3s ease;
  }

  .tc:hover .tc-avatar {
    animation: tc-glitch 0.4s steps(3) 1;
    box-shadow:
      0 0 24px color-mix(in srgb, var(--color-brand) 40%, transparent),
      0 0 48px color-mix(in srgb, var(--color-brand) 15%, transparent);
  }

  @keyframes tc-glitch {
    0%   { transform: translate(0, 0);     filter: hue-rotate(0deg) brightness(1); }
    16%  { transform: translate(-3px, 2px); filter: hue-rotate(60deg) brightness(1.2); }
    33%  { transform: translate(2px, -2px); filter: hue-rotate(-40deg) brightness(0.9); }
    50%  { transform: translate(-2px, 0);   filter: hue-rotate(90deg) brightness(1.3); }
    66%  { transform: translate(3px, 1px);  filter: hue-rotate(-60deg) brightness(1.1); }
    83%  { transform: translate(-1px, -1px);filter: hue-rotate(30deg) brightness(1); }
    100% { transform: translate(0, 0);      filter: hue-rotate(0deg) brightness(1); }
  }

  .tc-avatar-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
  }

  .tc-initials {
    color: #fff;
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1;
    text-shadow: 0 0 12px color-mix(in srgb, var(--color-brand) 40%, transparent);
  }

  /* ── Name ── */
  .tc-name {
    font-size: 1.15rem;
    font-weight: 650;
    color: var(--color-text-primary);
    margin: 1rem 0 0;
    line-height: 1.3;
  }

  .tc-bar {
    width: 40px;
    height: 2px;
    margin: 0.5rem auto 0;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--color-brand), var(--color-brand-light));
    opacity: 0.7;
    transition: width 0.3s ease;
  }

  .tc:hover .tc-bar {
    width: 56px;
  }

  /* ── Role ── */
  .tc-role {
    display: inline-block;
    margin-top: 0.6rem;
    padding: 0.2rem 0.65rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.675rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-brand);
    background: color-mix(in srgb, var(--color-brand) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand) 18%, transparent);
    border-radius: 100px;
  }

  /* ── Bio: fades out on hover (delayed so glitch plays first) ── */
  .tc-bio {
    margin-top: 0.85rem;
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 28ch;
    transition: opacity 0.25s ease 0.2s, transform 0.25s ease 0.2s;
  }

  .tc:hover .tc-bio {
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
  }

  /* ── Socials: appear after glitch + bio fade ── */
  .tc-socials {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    position: absolute;
    bottom: 1.75rem;
    left: 1.5rem;
    right: 1.5rem;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.3s ease 0.35s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1) 0.35s;
    pointer-events: none;
  }

  .tc:hover .tc-socials {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* ── Social icon circle ── */
  .tc-social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    text-decoration: none;
    color: var(--color-brand);
    background: color-mix(in srgb, var(--color-brand) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand) 18%, transparent);
    border-radius: 50%;
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tc-social:hover {
    background: color-mix(in srgb, var(--color-brand) 14%, transparent);
    border-color: var(--color-brand);
    box-shadow: 0 0 12px color-mix(in srgb, var(--color-brand) 25%, transparent);
    animation: tc-glitch 0.3s steps(3) 1;
  }
</style>
