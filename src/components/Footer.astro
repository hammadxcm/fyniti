---
import { siteConfig, footerLinks } from '@data/site';
---

<footer class="site-footer" role="contentinfo">
  <!-- Animated gradient top border -->
  <div class="footer-wave" aria-hidden="true"></div>

  <!-- Ambient orb -->
  <div class="ambient-orb" style="bottom: 10%; left: -8%; width: 350px; height: 350px; --orb-color: var(--color-brand); opacity: 0.05;"></div>

  <div class="footer-inner section" style="position: relative; z-index: 1;">
    <!-- Main grid -->
    <div class="footer-grid">
      <!-- Column 1: Brand -->
      <div class="footer-brand">
        <a href="#" class="footer-logo" aria-label="FYNITI home">
          <svg class="footer-logo-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 360 80" fill="currentColor" overflow="visible" aria-label="FYNITI">
            <rect x="0" y="0" width="56" height="12"/><rect x="0" y="0" width="12" height="80"/><rect x="0" y="34" width="40" height="12"/>
            <rect x="76" y="0" width="12" height="28"/><rect x="120" y="0" width="12" height="28"/><rect x="86" y="22" width="14" height="12"/><rect x="108" y="22" width="14" height="12"/><rect x="96" y="32" width="16" height="48"/>
            <rect x="152" y="0" width="12" height="80"/><rect x="208" y="0" width="12" height="80"/><rect x="164" y="8" width="12" height="14"/><rect x="174" y="20" width="12" height="14"/><rect x="184" y="32" width="12" height="14"/><rect x="196" y="44" width="12" height="14"/>
            <rect x="240" y="0" width="12" height="80"/>
            <rect x="272" y="0" width="56" height="12"/><rect x="294" y="0" width="12" height="80"/>
            <rect x="348" y="0" width="12" height="80"/>
          </svg>
        </a>
        <p class="text-text-secondary text-sm leading-relaxed mt-3 mb-5">
          {siteConfig.tagline}. Delivering innovative IT solutions that empower businesses to thrive in the digital age.
        </p>
        <div class="social-links" aria-label="Social media links">
          <!-- LinkedIn -->
          <a href="https://www.linkedin.com/company/105102524/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M4.5 3a1.5 1.5 0 110 3 1.5 1.5 0 010-3zM3 8h3v9H3V8zm5.5 0H11v1.2h.03c.35-.66 1.2-1.35 2.47-1.35 2.64 0 3.13 1.74 3.13 4v5.15h-3V12.4c0-1.1-.02-2.5-1.53-2.5-1.53 0-1.76 1.2-1.76 2.43V17h-3V8z" />
            </svg>
          </a>
          <!-- Twitter / X -->
          <a href="https://x.com/fyniti_uk" class="social-link" aria-label="Twitter / X" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M18 4.5a7.5 7.5 0 01-2.15.59A3.75 3.75 0 0017.5 3a7.5 7.5 0 01-2.37.9A3.75 3.75 0 008.25 7a10.6 10.6 0 01-7.7-3.9 3.75 3.75 0 001.16 5A3.75 3.75 0 01.5 7.7v.05a3.75 3.75 0 003 3.67 3.75 3.75 0 01-1.7.06 3.75 3.75 0 003.5 2.6A7.5 7.5 0 010 15.6 10.6 10.6 0 005.75 17c6.9 0 10.7-5.7 10.7-10.7l-.01-.49A7.5 7.5 0 0018 4.5z" />
            </svg>
          </a>
          <!-- GitHub -->
          <a href="https://github.com/hammadxcm" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M10 1a9 9 0 00-2.84 17.54c.45.08.62-.2.62-.43v-1.52c-2.51.55-3.04-1.21-3.04-1.21-.41-1.04-1-1.32-1-1.32-.82-.56.06-.55.06-.55.91.06 1.39.93 1.39.93.8 1.38 2.11.98 2.63.75.08-.58.31-.98.57-1.2-2.01-.23-4.12-1-4.12-4.47 0-.99.35-1.8.93-2.43-.09-.23-.4-1.15.09-2.4 0 0 .76-.24 2.48.93a8.6 8.6 0 014.52 0c1.72-1.17 2.48-.93 2.48-.93.49 1.25.18 2.17.09 2.4.58.63.93 1.44.93 2.43 0 3.48-2.12 4.24-4.13 4.46.32.28.61.83.61 1.68v2.49c0 .24.16.52.62.43A9 9 0 0010 1z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Services -->
      <div>
        <h4 class="footer-heading">Services</h4>
        <ul class="footer-link-list" role="list">
          {footerLinks.services.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Company -->
      <div>
        <h4 class="footer-heading">Company</h4>
        <ul class="footer-link-list" role="list">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="footer-link">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h4 class="footer-heading">Contact</h4>
        <ul class="footer-link-list footer-contact-list" role="list">
          <li class="footer-contact-item">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="16" height="12" rx="2" />
              <path d="M2 4l8 6 8-6" />
            </svg>
            <a href={`mailto:${siteConfig.email}`} class="footer-link">{siteConfig.email}</a>
          </li>
          <li class="footer-contact-item">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M3 2h4l2 5-3 2a11 11 0 005 5l2-3 5 2v4a2 2 0 01-2 2A16 16 0 012 4a2 2 0 012-2z" />
            </svg>
            <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="footer-link">{siteConfig.phone}</a>
          </li>
          <li class="footer-contact-item">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 18s-6-5.34-6-9a6 6 0 1112 0c0 3.66-6 9-6 9z" />
              <circle cx="10" cy="9" r="2" />
            </svg>
            <span class="footer-link-text">{siteConfig.location}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="text-text-secondary text-sm">
        &copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.
      </p>
      <p class="text-text-secondary text-sm">
        Built with &#10084;&#65039; in the UK
      </p>
    </div>
  </div>
</footer>

<style>
  /* ── Animated gradient top border ── */
  @keyframes gradient-flow {
    0% {
      background-position: 0% 50%;
    }
    100% {
      background-position: 200% 50%;
    }
  }

  .footer-wave {
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--color-brand),
      var(--color-brand-light),
      var(--color-brand-mint),
      var(--color-brand)
    );
    background-size: 200% 100%;
    animation: gradient-flow 4s linear infinite;
  }

  .site-footer {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-base);
  }

  .footer-inner {
    padding-top: 4rem;
    padding-bottom: 0;
  }

  /* ── Grid ── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      text-align: left;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 3rem;
    }
  }

  /* ── Brand column ── */
  .footer-logo-svg {
    height: 22px;
    width: auto;
    color: var(--color-brand);
    transition: filter 0.3s ease;
  }

  .footer-logo:hover .footer-logo-svg {
    filter: drop-shadow(0 0 6px var(--color-brand))
            drop-shadow(0 0 12px var(--color-brand));
  }

  .footer-logo {
    text-decoration: none;
    display: inline-block;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
  }

  @media (min-width: 640px) {
    .social-links { justify-content: flex-start; }
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-default);
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .social-link:hover {
    color: var(--color-brand);
    border-color: var(--color-brand);
    background: rgba(0, 168, 168, 0.08);
    transform: translateY(-2px);
  }

  /* ── Link columns ── */
  .footer-heading {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 1rem;
    letter-spacing: 0.01em;
  }

  .footer-link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-brand);
  }

  .footer-link-text {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  /* ── Contact items ── */
  .footer-contact-list {
    gap: 0.75rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-text-secondary);
  }

  .footer-contact-item svg {
    flex-shrink: 0;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 2rem 0;
    margin-top: 3rem;
    border-top: 1px solid var(--color-border-default);
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-bottom p {
    margin: 0;
  }
</style>
